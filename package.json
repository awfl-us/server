{
  "name": "awfl-server",
  "description": "Express servers for API and Jobs (Cloud Run) with local dev via dev.js",
  "type": "module",
  "scripts": {
    "dev": "node dev.js",
    "start:api": "node api.server.js",
    "start:jobs": "node jobs.server.js",
    "dev:api": "nodemon api.server.js",
    "dev:jobs": "nodemon jobs.server.js",
    "test": "mocha test.js",
    "test:jest": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --env=node",
    "test:context": "npm run -s test:jest -- --config ./jest.config.mjs"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.1.0",
    "@google-cloud/tasks": "^6.1.0",
    "@google-cloud/workflows": "^4.1.0",
    "@kubernetes/client-node": "^0.21.0",
    "@langchain/openai": "^0.5.7",
    "@sendgrid/mail": "^8.1.4",
    "axios": "^1.7.8",
    "busboy": "^1.6.0",
    "chai": "^5.1.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "express": "^4.21.1",
    "firebase-admin": "^13.0.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^148.0.0",
    "libphonenumber-js": "^1.12.4",
    "mocha": "^10.8.2",
    "openai": "^4.73.1",
    "sinon": "^19.0.2",
    "supertest": "^7.0.0",
    "twilio": "^5.4.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.10"
  },
  "private": true
}
